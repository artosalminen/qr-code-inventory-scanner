// Real-Time Inventory Tracking & Handoff System
// Complete database schema with PostgreSQL provider via Prisma Data Proxy
// Version: 1.0.0

generator client {
  provider = "prisma-client-js"
  engineType = "node"
}

datasource db {
  provider = "sqlserver"
}

// ============================================================================
// TYPE DEFINITIONS (validated in application code)
// ============================================================================
// BoxState values: RECEIVED, IN_USE, READY_FOR_CHECKOUT, DEPARTED
// UserRole values: admin, inventory_management, installation, read_only
// ChangeType values: state_change, condition_update, note_update, assignment_change
// ProjectStatus values: active, archived

// ============================================================================
// CORE TABLES
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  googleId      String?   @unique @map("google_id")
  avatar        String?
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  projectUsers      ProjectUser[]
  projectsCreated   Project[]
  stateChanges      BoxStateHistory[]
  stateChangesAs    BoxStateHistory[] @relation("installationUser")
  inUseSessions     BoxInUseSession[]
  projectUserAssign ProjectUser[] @relation("assignedBy")

  @@index([googleId])
  @@map("users")
}

model Project {
  id              String   @id @default(cuid())
  name            String
  description     String?
  status          String   @default("active") // Values: active, archived
  csvUploadedAt   DateTime? @map("csv_uploaded_at")
  defaultQrMode   String   @default("check-in") @map("default_qr_mode")
  createdBy       String   @map("created_by")
  archivedAt      DateTime? @map("archived_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  projectUsers    ProjectUser[]
  boxes           Box[]
  createdByUser   User     @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status])
  @@map("projects")
}

model ProjectUser {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   // Values: admin, inventory_management, installation, read_only
  assignedBy String? @map("assigned_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assignedByUser User?    @relation("assignedBy", fields: [assignedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, userId], name: "idx_project_user_unique")
  @@index([projectId])
  @@index([userId])
  @@map("project_users")
}

model Box {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  qrCode      String   @map("qr_code")
  label       String?
  description String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stateHistory  BoxStateHistory[]
  inUseSessions BoxInUseSession[]

  @@unique([projectId, qrCode], name: "idx_project_qrcode_unique")
  @@index([projectId])
  @@map("boxes")
}

model BoxStateHistory {
  id                String   @id @default(cuid())
  boxId             String   @map("box_id")
  stateSetBy        String   @map("state_set_by")
  state             String   @map("state") // Values: RECEIVED, IN_USE, READY_FOR_CHECKOUT, DEPARTED
  installationUser  String?  @map("installation_user")
  changeType        String   @map("change_type") // Values: state_change, condition_update, note_update, assignment_change

  // Condition & damage tracking
  condition         String?  // 'ok' or 'damaged'
  brokenItems       String?  @map("broken_items") // Free-text list of damaged items
  notes             String?

  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  box               Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  stateSetByUser    User     @relation(fields: [stateSetBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  installationUserRel User?  @relation("installationUser", fields: [installationUser], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([boxId])
  @@index([stateSetBy])
  @@index([state])
  @@index([createdAt])
  @@map("box_state_history")
}

model BoxInUseSession {
  id                  String   @id @default(cuid())
  boxId               String   @map("box_id")
  installationUserId  String   @map("installation_user_id")
  activatedAt         DateTime @default(now()) @map("activated_at")
  completedAt         DateTime? @map("completed_at")
  usageNotes          String?  @map("usage_notes")

  // Relations
  box                 Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  installationUser    User     @relation(fields: [installationUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([boxId])
  @@index([installationUserId])
  @@index([activatedAt])
  @@map("box_in_use_sessions")
}
