# Database Configuration
# For local development, use a local SQL Server instance or Azure SQL free tier
# Format: mssql://[user]:[password]@[host]:[port]/[database]?schema=[schema]
# Example: mssql://sa:YourPassword123@localhost:1433/inventory?schema=dbo
DATABASE_URL="mssql://user:password@host:port/database?schema=dbo"

# Node Environment
NODE_ENV=development

# NextAuth Configuration
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# Google OAuth 2.0 Configuration
# Create credentials at: https://console.cloud.google.com/
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Application Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
LOG_LEVEL=info
