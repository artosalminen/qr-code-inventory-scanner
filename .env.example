# Database Configuration
# IMPORTANT: Use sqlserver:// protocol (not mssql://) for Prisma with SQL Server
# Format: sqlserver://[username]:[password]@[hostname]:[port];database=[database];[additional options]

# For Azure SQL (recommended for production):
# DATABASE_URL="sqlserver://{username}@{servername}:{password}@{servername}.database.windows.net:1433;database={database};encrypt=true;trustServerCertificate=false;connectionTimeout=30;"

# For local SQL Server:
# DATABASE_URL="sqlserver://sa:YourPassword123@localhost:1433;database=inventory_db;encrypt=true;trustServerCertificate=true;"

# Example with your Azure SQL setup:
# DATABASE_URL="sqlserver://my_username@inventory-management-db-rc:my_password@inventory-management-db-rc.database.windows.net:1433;database=inventory-management-db-dev;encrypt=true;trustServerCertificate=false;connectionTimeout=30;"

DATABASE_URL="sqlserver://username@servername:password@servername.database.windows.net:1433;database=database_name;encrypt=true;trustServerCertificate=false;connectionTimeout=30;"

# Node Environment
NODE_ENV=development

# NextAuth Configuration
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# Google OAuth 2.0 Configuration
# Create credentials at: https://console.cloud.google.com/
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Socket.io Configuration (Optional, defaults to same origin)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Application Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
LOG_LEVEL=info
